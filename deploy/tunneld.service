[Unit]
Description=tunneld - tunnel relay server
After=network.target

[Service]
Type=simple
ExecStart=/opt/tunnel/tunneld -config /opt/tunnel/tunneld.yml
Restart=on-failure
RestartSec=5
User=tunneld
# Uncomment if you configure allowed_port_range below 1024 (e.g. to expose
# port 80/443 directly) - binding privileged ports needs this capability
# instead of running as root:
# AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
